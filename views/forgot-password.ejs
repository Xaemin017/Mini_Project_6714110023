<%- include('head') %>
<%- include('navbar') %>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh; padding-top: 100px;">
    <div class="card shadow border-0 p-4" style="width: 100%; max-width: 400px; border-radius: 20px;">
        <div class="card-body text-center">
            <i class="fas fa-key fa-3x text-warning mb-3"></i>
            <h4 class="font-weight-bold">ลืมรหัสผ่าน?</h4>
            <p class="text-muted small">กรอกอีเมลของคุณเพื่อรับลิงก์ตั้งค่ารหัสผ่านใหม่</p>

            <form action="/forgot-password" method="POST">
                <div class="form-group text-left">
                    <input type="email" name="email" class="form-control rounded-pill" placeholder="example@email.com" required>
                </div>
                <button type="submit" class="btn btn-etech btn-block rounded-pill">ส่งลิงก์รีเซ็ตรหัสผ่าน</button>
            </form>
            
            <a href="/login" class="d-block mt-3 small text-muted">กลับไปหน้าเข้าสู่ระบบ</a>
        </div>
    </div>
</div>

<%- include('footer') %>