<%- include('head') %>
<%- include('navbar') %>

<div class="container-fluid py-4 bg-light" style="min-height: 100vh;">
    <div class="row px-lg-5">
        
        <div class="col-lg-3 col-md-4 mb-4">
            <div class="card border-0 shadow-sm sticky-sidebar" style="border-radius: 20px;">
                <div class="card-body p-4">
                    <h5 class="font-weight-bold mb-4 text-primary"><i class="fas fa-filter mr-2"></i> ตัวกรองสินค้า</h5>
                    
                    <p class="font-weight-bold mb-2 small text-uppercase">ยี่ห้อ</p>
                    <div class="list-group list-group-flush mb-4">
                        <a href="/" class="list-group-item list-group-item-action border-0 px-0 rounded font-weight-bold">ทั้งหมด</a>
                        <% brands.forEach(function(b) { %>
                            <a href="/brand/<%= b %>" class="list-group-item list-group-item-action border-0 px-0"><%= b %></a>
                        <% }) %>
                    </div>

                    <p class="font-weight-bold mb-2 small text-uppercase">ระบุช่วงราคาเอง</p>
                    <form action="/search" method="GET">
                        <div class="form-row align-items-center">
                            <div class="col-5">
                                <input type="number" name="min" class="form-control form-control-sm" placeholder="ต่ำสุด">
                            </div>
                            <div class="col-2 text-center text-muted small">ถึง</div>
                            <div class="col-5">
                                <input type="number" name="max" class="form-control form-control-sm" placeholder="สูงสุด">
                            </div>
                        </div>
                        <button type="submit" class="btn btn-etech btn-sm btn-block mt-3 rounded-pill">ค้นหาราคา</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-9 col-md-8">
            <div class="mb-4">
                <h2 class="font-weight-bold mb-0 text-dark"><%= title %></h2>
                <p class="text-muted small">พบสินค้าทั้งหมด <%= products.length %> รายการ</p>
            </div>

            <div class="row">
                <% products.forEach(function(item) { %>
                    <div class="col-xl-4 col-lg-6 mb-4">
                        <div class="card h-100 border-0 shadow-sm product-card" style="border-radius: 20px; overflow: hidden;">
                            <div class="p-3 text-center bg-white">
                                <a href="/<%= item._id %>">
                                    <img src="/images/products/<%= item.image %>" style="height: 180px; object-fit: contain; width: 100%;">
                                </a>
                            </div>
                            <div class="card-body text-center pt-0">
                                <span class="badge badge-light text-muted mb-2"><%= item.brand %></span>
                                <h6 class="font-weight-bold text-truncate"><%= item.name %></h6>
                                <div class="mb-3">
                                    <% if(item.oldPrice > item.price) { %>
                                        <small class="text-muted" style="text-decoration: line-through;">฿<%= item.oldPrice.toLocaleString() %></small>
                                        <span class="text-danger font-weight-bold ml-1">฿<%= item.price.toLocaleString() %></span>
                                    <% } else { %>
                                        <span class="text-dark font-weight-bold">฿<%= item.price.toLocaleString() %></span>
                                    <% } %>
                                </div>
                                <a href="/<%= item._id %>" class="btn btn-etech btn-sm btn-block rounded-pill">รายละเอียด</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
            
        </div>

    </div>
</div>

<%- include('footer') %>