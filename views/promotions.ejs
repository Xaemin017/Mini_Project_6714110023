<%- include('head') %>
<%- include('navbar') %>

<div class="container-fluid py-4" style="background-color: #f8f9fa; min-height: 100vh;">
    <div class="row px-lg-5">
        
        <div class="col-lg-3 col-md-4 mb-4">
            <div class="card border-0 shadow-sm sticky-top" style="border-radius: 20px; top: 90px;">
                <div class="card-body p-4">
                    <h5 class="font-weight-bold mb-4 text-danger">
                        <i class="fas fa-fire mr-2"></i> กรองโปรโมชั่น
                    </h5>
                    
                    <p class="font-weight-bold mb-2 small text-uppercase text-muted">เลือกยี่ห้อ</p>
                    <div class="list-group list-group-flush mb-4">
                        <a href="/promotions" class="list-group-item list-group-item-action border-0 px-0 rounded">ทั้งหมด</a>
                        <% brands.forEach(function(b) { %>
                            <a href="/promotions?brand=<%= b %>" class="list-group-item list-group-item-action border-0 px-0"><%= b %></a>
                        <% }) %>
                    </div>

                    <p class="font-weight-bold mb-2 small text-uppercase text-muted">ระบุช่วงราคาพิเศษ</p>
                    <form action="/promotions" method="GET">
                        <% if(locals.currentBrand) { %><input type="hidden" name="brand" value="<%= currentBrand %>"><% } %>
                        <div class="form-row">
                            <div class="col-5">
                                <input type="number" name="min" class="form-control form-control-sm" placeholder="ต่ำสุด">
                            </div>
                            <div class="col-2 text-center text-muted small mt-1">ถึง</div>
                            <div class="col-5">
                                <input type="number" name="max" class="form-control form-control-sm" placeholder="สูงสุด">
                            </div>
                        </div>
                        <button type="submit" class="btn btn-etech btn-sm btn-block mt-3 rounded-pill">ค้นหาราคา</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-9 col-md-8">
            <div class="text-center mb-5">
                <h1 class="display-4 font-weight-bold text-danger"><%= title %></h1>
                <p class="text-muted">Gaming Set & Gadgets ราคาพิเศษ ลดแรงแซงทุกดีล!</p>
            </div>

            <div class="row">
                <% if (products.length > 0) { %>
                    <% products.forEach(function(item) { %>
                        <div class="col-xl-4 col-lg-6 mb-4">
                            <div class="card h-100 border-0 shadow-sm product-card" style="border-radius: 20px; overflow: hidden; transition: 0.3s;">
                                
                                <div class="position-absolute p-3" style="z-index: 10;">
                                    <span class="badge badge-danger px-3 py-2" style="border-radius: 10px; font-size: 0.9rem;">
                                        SAVE <%= Math.round((1 - item.price/item.oldPrice) * 100) %>%
                                    </span>
                                </div>
                                
                                <div class="p-4 text-center bg-white">
                                    <a href="/<%= item._id %>">
                                        <img src="/images/products/<%= item.image %>" style="height: 180px; width: 100%; object-fit: contain;">
                                    </a>
                                </div>
                                
                                <div class="card-body text-center pt-0">
                                    <p class="small text-muted mb-1"><%= item.brand %></p>
                                    <h6 class="font-weight-bold text-truncate mb-2"><%= item.name %></h6>
                                    
                                    <div class="mb-3">
                                        <small class="text-muted" style="text-decoration: line-through;">฿<%= item.oldPrice.toLocaleString() %></small>
                                        <span class="text-danger h5 font-weight-bold ml-2">฿<%= item.price.toLocaleString() %></span>
                                    </div>

                                    <div class="row no-gutters">
                                        <div class="col-5 pr-1">
                                            <a href="/<%= item._id %>" class="btn btn-outline-dark btn-sm btn-block rounded-pill">
                                                ข้อมูลสินค้า
                                            </a>
                                        </div>
                                        <div class="col-7 pl-1">
                                            <a href="/cart/add/<%= item._id %>" class="btn btn-etechS btn-sm btn-block rounded-pill">
                                                <i class="fas fa-cart-plus mr-1"></i> เพิ่มลงตะกร้า
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-12 text-center py-5">
                        <h4 class="text-muted">ไม่พบสินค้าโปรโมชั่นในขณะนี้</h4>
                        <a href="/" class="btn btn-etech mt-3 rounded-pill">ไปดูสินค้าทั้งหมด</a>
                    </div>
                <% } %>
            </div>
        </div>

    </div>
</div>

<%- include('footer') %>