<%- include('head') %>
<%- include('navbar') %>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2><i class="fas fa-boxes"></i> จัดการสินค้า</h2>
            <p class="text-muted">คลังสินค้าปัจจุบันในระบบ</p>
        </div>
        <a href="/addForm" class="btn btn-success"><i class="fas fa-plus"></i> เพิ่มสินค้าใหม่</a>
    </div>
    
    <div class="input-group mb-3 shadow-sm">
        <div class="input-group-prepend">
            <span class="input-group-text bg-white border-right-0"><i class="fas fa-search text-muted"></i></span>
        </div>
        <input type="text" id="searchInput" class="form-control border-left-0" placeholder="พิมพ์ชื่อสินค้า, ราคา หรือรายละเอียดเพื่อค้นหา...">
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover bg-white mb-0">
            <thead class="thead-dark">
                <tr>
                    <th style="width: 15%">รูปภาพ</th>
                    <th style="width: 25%">ชื่อสินค้า</th>
                    <th style="width: 15%">ราคา</th>
                    <th style="width: 25%">รายละเอียด</th>
                    <th style="width: 20%" class="text-center">จัดการ</th>
                </tr>
            </thead>
            <tbody id="productTable">
                <% Object.values(products).forEach(function(item){ %>
                <tr>
                    <td class="align-middle text-center">
                        <img src="/images/products/<%= item.image %>" alt="<%= item.name %>"
                             class="img-thumbnail" style="width: 80px; height: 80px; object-fit: cover;">
                    </td>
                    <td class="align-middle font-weight-bold name"><%= item.name %></td>
                    <td class="align-middle text-primary price font-weight-bold">
                        ฿<%= item.price.toLocaleString() %>
                    </td>
                    <td class="align-middle text-muted description">
                        <small><%= item.description.substring(0, 50) %><%= item.description.length > 50 ? '...' : '' %></small>
                    </td>
                    <td class="align-middle text-center">
                        <div class="d-flex justify-content-center">
                            <form action="/edit" method="POST" class="mr-2">
                                <input type="hidden" value="<%= item._id %>" name="id">
                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-edit"></i> แก้ไข
                                </button>
                            </form>
                            <a class="btn btn-sm btn-outline-danger" href="/delete/<%= item._id %>" 
                               onclick="return confirm('ยืนยันการลบสินค้า: <%= item.name %> ?')">
                                <i class="fas fa-trash"></i> ลบ
                            </a>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<script>
    // ระบบค้นหาแบบ Real-time
    document.getElementById("searchInput").addEventListener("keyup", function () {
        let filter = this.value.toLowerCase();
        let rows = document.querySelectorAll("#productTable tr");

        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            row.style.display = text.includes(filter) ? "" : "none";
        });
    });
</script>